<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Books</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#f4f6f9;
            padding:40px;
        }

        .container{
            max-width:1100px;
            margin:auto;
        }

        .header{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:25px;
        }

        h1{
            color:#333;
        }

        .add-btn{
            text-decoration:none;
            background:#28a745;
            color:white;
            padding:12px 18px;
            border-radius:8px;
            font-weight:bold;
            transition:0.3s;
        }

        .add-btn:hover{
            background:#218838;
        }

        table{
            width:100%;
            border-collapse:collapse;
            background:white;
            border-radius:10px;
            overflow:hidden;
            box-shadow:0 5px 15px rgba(0,0,0,0.1);
        }

        th{
            background:#007bff;
            color:white;
            padding:15px;
        }

        td{
            padding:15px;
            text-align:center;
            border-bottom:1px solid #ddd;
        }

        tr:hover{
            background:#f1f1f1;
        }

        .edit-btn{
            text-decoration:none;
            background:#ffc107;
            color:black;
            padding:8px 12px;
            border-radius:5px;
            margin-right:5px;
            font-weight:bold;
        }

        .edit-btn:hover{
            background:#e0a800;
        }

        .delete-btn{
            text-decoration:none;
            background:#dc3545;
            color:white;
            padding:8px 12px;
            border-radius:5px;
            font-weight:bold;
        }

        .delete-btn:hover{
            background:#c82333;
        }

        .home-btn{
            display:inline-block;
            margin-top:20px;
            text-decoration:none;
            background:#343a40;
            color:white;
            padding:10px 18px;
            border-radius:8px;
        }

        .home-btn:hover{
            background:#23272b;
        }

    </style>

</head>
<body>

    <div class="container">

        <div class="header">

            <h1>📚 Library Books</h1>

            <a href="/addbook" class="add-btn">
                + Add Book
            </a>

        </div>

        <table>

            <tr>
                <th>Book Name</th>
                <th>Author</th>
                <th>Category</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Actions</th>
            </tr>

            <% books.forEach((book)=>{ %>

                <tr>

                    <td>
                        <%= book.bookName %>
                    </td>

                    <td>
                        <%= book.author %>
                    </td>

                    <td>
                        <%= book.category %>
                    </td>

                    <td>
                        ₹ <%= book.price %>
                    </td>

                    <td>
                        <%= book.quantity %>
                    </td>

                    <td>

                        <a
                            href="/edit/<%= book._id %>"
                            class="edit-btn"
                        >
                            Edit
                        </a>

                        <a
                            href="/delete/<%= book._id %>"
                            class="delete-btn"
                            onclick="return confirm('Delete this book?')"
                        >
                            Delete
                        </a>

                    </td>

                </tr>

            <% }) %>

        </table>

        <a href="/" class="home-btn">
            ⬅ Back To Home
        </a>

    </div>

</body>
</html>